PORT=3001
NODE_ENV=development

# Postgres (used by Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/helix?schema=public

# Auth
JWT_SECRET=dev_change_me

# Payments: "stripe" or "mock"
PAYMENTS_MODE=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PUBLIC_APP_URL=http://localhost:5173

# Download URL signing (HMAC for demo signed URLs)
DOWNLOAD_SIGNING_SECRET=dev_change_me_too

# Optional integrations
SENDGRID_API_KEY=
SUPPORT_ESCALATION_EMAIL=support@example.com
LEAD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

